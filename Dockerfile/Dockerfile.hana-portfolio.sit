# Use node:lts-alpine3.24 as builder image
FROM node:lts-alpine3.24 AS builder

# Configure image maintainer
LABEL maintainer="Nicklas373 <herlambangdicky5@gmail.com>"
LABEL version="1.0.4"
LABEL description="Docker container for https://portfolio.hana-ci.com/dickyherlambang"

# Configure work directory
WORKDIR /app

# Configure initial package
COPY package*.json ./

# Installing initial package
RUN npm ci

# Copy other data
COPY . .

# Compiling node packages
RUN npm run build

# Use node:26-alpine3.24 as base image
FROM node:26-alpine3.24

# Configure work directory
WORKDIR /app

# Configure Environment
ENV NODE_ENV=development

# Copying data from builder stage
COPY --from=builder /app/public ./public
COPY --from=builder /app/next.config.* ./
COPY --from=builder /app/package*.json ./
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

# Expose port
EXPOSE 3000

# Start Next JS
CMD ["node", "server.js"]